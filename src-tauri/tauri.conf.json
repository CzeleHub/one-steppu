{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "onestep",
  "version": "0.1.0",
  "identifier": "com.czele.onesteppu",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "onesteppu",
        "width": 1000,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 800,
        "url": "web/index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "rpm",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["lessons/*"]
  }
}
